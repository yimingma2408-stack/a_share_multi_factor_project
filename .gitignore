# macOS
.DS_Store
**/.DS_Store

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
build/
dist/

# Jupyter
.ipynb_checkpoints/

# Environment
.env
.venv/
venv/
env/

# VS Code local settings
.vscode/

# Raw and processed data
data/raw/*
data/processed/*

# Keep folder structure
!data/raw/.gitkeep
!data/processed/.gitkeep

# Large outputs
*.csv
*.parquet
*.pkl
*.h5

# Compact report tables are review artifacts, not data caches.
!reports/**/*.csv

# Regenerable report figures and formal-EOT parallel recompute shards.
reports/**/figures/*.png
reports/**/figures_*/*.png
data/processed/eot_factor_lifecycle_test/shard_*_panel.parquet
data/processed/eot_factor_lifecycle_test/shard_*_coordinates.parquet
reports/eot_factor_lifecycle_test/shard_*_computation.csv

# Explicit generated-cache roots
.cache/
artifacts/cache/

# Result outputs
results/figures/*
results/tables/*

# Keep result folders
!results/figures/.gitkeep
!results/tables/.gitkeep

# Logs
*.log

# Local coverage/tooling outputs
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
